# LabscriptAI 后端环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ===========================================
# 应用基础配置
# ===========================================
# 应用环境 (development/production/testing)
ENVIRONMENT=production

# 服务器配置
HOST=0.0.0.0
PORT=8000

# API基础地址配置
API_BASE_URL=https://api.ai4ot.cn

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# ===========================================
# API 密钥配置
# ===========================================
# OpenAI API 配置 (项目实际使用的配置)
OPENAI_API_KEY=sk-Fbf6T3Gd8o3srcifmRyfUa3PfKmtbNuYgNzind0j92h2sV3n
OPENAI_BASE_URL=https://api.ai190.com/v1
OPENAI_MODEL=gemini-2.5-pro

# DeepSeek API 配置 (用于意图分类的快速模型)
DEEPSEEK_API_KEY=C5dgRQ47zWYzeNGpS7YU9kQIEoP4KiGfPDdnrnLFwRE1AJaUCNN5acwtACD69-XPyOiqPI8H5tFMHJLxVuAJQA
DEEPSEEK_BASE_URL=https://www.sophnet.com/api/open-apis/v1
DEEPSEEK_INTENT_MODEL=DeepSeek-V3-Fast

# 其他AI服务API密钥（如需要）
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here

# ===========================================
# 数据库配置（如使用）
# ===========================================
# DATABASE_URL=postgresql://user:password@localhost:5432/labscriptai
# REDIS_URL=redis://localhost:6379/0

# ===========================================
# 安全配置
# ===========================================
# JWT密钥（用于身份验证）
SECRET_KEY=your_secret_key_here_change_in_production

# CORS允许的域名
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://ai4ot.cn,https://api.ai4ot.cn,http://api.ai4ot.cn

# ===========================================
# 外部服务配置
# ===========================================
# Opentrons相关配置
OPENTRONS_API_URL=http://localhost:31950

# PyLabRobot相关配置
PYLABROBOT_BACKEND=chatterbox

# ===========================================
# 文件存储配置
# ===========================================
# 上传文件存储路径
UPLOAD_DIR=/app/uploads

# 最大文件上传大小 (MB)
MAX_UPLOAD_SIZE=50

# ===========================================
# 性能配置
# ===========================================
# 工作进程数
WORKERS=1

# 请求超时时间 (秒)
REQUEST_TIMEOUT=300

# ===========================================
# 监控和健康检查
# ===========================================
# 健康检查端点
HEALTH_CHECK_PATH=/health

# 指标收集（如使用Prometheus）
# METRICS_ENABLED=true
# METRICS_PORT=9090

# ===========================================
# Python环境配置 (UV双环境支持)
# ===========================================
# UV包管理器配置
UV_CACHE_DIR=/app/.uv-cache
UV_PYTHON_DOWNLOADS=automatic

# Python虚拟环境路径
VIRTUAL_ENV=/app/.venv
PYTHONPATH=/app:/app/backend

# Python优化配置
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# UV项目配置
UV_PROJECT_ENVIRONMENT=/app/.venv
UV_COMPILE_BYTECODE=1

# ===========================================
# 开发调试配置
# ===========================================
# 开发模式配置
DEBUG=false
DEVELOPMENT_MODE=false

# 热重载配置（开发环境）
# RELOAD=true
# RELOAD_DIRS=/app/backend

# ===========================================
# 前端集成配置
# ===========================================
# 前端应用地址
FRONTEND_URL=https://ai4ot.cn

# 静态文件服务配置
STATIC_FILES_DIR=/app/static
STATIC_URL_PATH=/static