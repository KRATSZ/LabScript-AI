# LabscriptAI 后端环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ===========================================
# 应用基础配置
# ===========================================
# 应用环境 (development/production/testing)
ENVIRONMENT=production

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# ===========================================
# API 密钥配置
# ===========================================
# OpenAI API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# 其他AI服务API密钥（如需要）
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here

# ===========================================
# 数据库配置（如使用）
# ===========================================
# DATABASE_URL=postgresql://user:password@localhost:5432/labscriptai
# REDIS_URL=redis://localhost:6379/0

# ===========================================
# 安全配置
# ===========================================
# JWT密钥（用于身份验证）
SECRET_KEY=your_secret_key_here_change_in_production

# CORS允许的域名
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://ai4ot.cn,https://api.ai4ot.cn

# ===========================================
# 外部服务配置
# ===========================================
# Opentrons相关配置
OPENTRONS_API_URL=http://localhost:31950

# PyLabRobot相关配置
PYLABROBOT_BACKEND=chatterbox

# ===========================================
# 文件存储配置
# ===========================================
# 上传文件存储路径
UPLOAD_DIR=/app/uploads

# 最大文件上传大小 (MB)
MAX_UPLOAD_SIZE=50

# ===========================================
# 性能配置
# ===========================================
# 工作进程数
WORKERS=1

# 请求超时时间 (秒)
REQUEST_TIMEOUT=300

# ===========================================
# 监控和健康检查
# ===========================================
# 健康检查端点
HEALTH_CHECK_PATH=/health

# 指标收集（如使用Prometheus）
# METRICS_ENABLED=true
# METRICS_PORT=9090