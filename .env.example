# LabscriptAI 环境变量配置文件
# 复制此文件为 .env 并根据需要修改配置

# ===== 应用基础配置 =====
# 运行环境: development, production, testing
LABSCRIPTAI_ENVIRONMENT=development

# ===== LLM API 配置 =====

# OpenAI 配置 (主要用于协议生成、代码优化、复杂推理等核心功能模块)
LABSCRIPTAI_API_KEY=your-openai-api-key-here
LABSCRIPTAI_BASE_URL=https://api.openai.com/v1
LABSCRIPTAI_MODEL_NAME=gpt-4

# DeepSeek 配置 (专用于langchain_agent和pylabrobot_agent中的意图识别与快速对话模块)
LABSCRIPTAI_DEEPSEEK_API_KEY=your-deepseek-api-key-here
LABSCRIPTAI_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LABSCRIPTAI_DEEPSEEK_MODEL=deepseek-chat

# ===== 服务器配置 =====
LABSCRIPTAI_SERVER_HOST=0.0.0.0
LABSCRIPTAI_SERVER_PORT=8000
LABSCRIPTAI_DEBUG=false

# ===== 数据库配置 =====
# SQLite (默认)
LABSCRIPTAI_DATABASE_URL=sqlite:///./labscriptai.db

# PostgreSQL (生产环境推荐)
# LABSCRIPTAI_DATABASE_URL=postgresql://username:password@localhost:5432/labscriptai

# ===== 日志配置 =====
LABSCRIPTAI_LOG_LEVEL=INFO

# ===== 环境示例 =====

# 生产环境示例
# LABSCRIPTAI_ENVIRONMENT=production
# LABSCRIPTAI_DEBUG=false
# LABSCRIPTAI_LOG_LEVEL=WARNING
# LABSCRIPTAI_DATABASE_URL=postgresql://user:pass@localhost:5432/labscriptai

# 开发环境示例
# LABSCRIPTAI_ENVIRONMENT=development
# LABSCRIPTAI_DEBUG=true
# LABSCRIPTAI_LOG_LEVEL=DEBUG

# 测试环境示例
# LABSCRIPTAI_ENVIRONMENT=testing
# LABSCRIPTAI_DATABASE_URL=sqlite:///./test_labscriptai.db
# LABSCRIPTAI_LOG_LEVEL=ERROR