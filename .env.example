# LabscriptAI shared environment variables
# Copy this file to `.env` at the project root and adjust the values as needed.

# ===== Frontend (shared with Vite via labscriptAI-frontend/vite.config.ts) =====
# Leave blank to use same-origin `/api` requests behind a reverse proxy.
# For local split frontend/backend development, set `http://localhost:8000`.
VITE_API_BASE_URL=
VITE_DEV_MODE=true

# ===== Backend application =====
LABSCRIPTAI_ENVIRONMENT=development
LABSCRIPTAI_SERVER_HOST=0.0.0.0
LABSCRIPTAI_SERVER_PORT=8000
LABSCRIPTAI_DEBUG=false

# ===== Main LLM service =====
LABSCRIPTAI_API_KEY=
LABSCRIPTAI_BASE_URL=https://api.labscriptai.cn/v1
LABSCRIPTAI_MODEL_NAME=glm-4.7-fast

# ===== Fast / intent LLM service =====
# If left blank, the backend will fall back to the main LLM settings above.
LABSCRIPTAI_DEEPSEEK_API_KEY=
LABSCRIPTAI_DEEPSEEK_BASE_URL=
LABSCRIPTAI_DEEPSEEK_MODEL=

# ===== Optional external services =====
LABSCRIPTAI_FIGSHARE_PERSONAL_TOKEN=
